module test;

use slate;
use compiler;
use analyse;

void cmd_test(list(string) args) {
    if args.len() < 2 {
        print("slate test: no file given.");
        print("usage: slate test <file>");
        return;
    }
    string path = args.get(1);
    if file(path).exists() == false {
        print(red("error") + ": file not found: " + bold_slate(path));
        return;
    }

    mutable AnalysisResult ar = analyse_source(path, false);

    string source = file(path).read();
    if ar.errors.len() > 0 {
        string output = render_all(ar.errors, ar.warnings, source);
        print(output);
        return;
    }

    list(string) lines = source.split("\n");
    mutable int found = 0;
    mutable int i = 0;
    while i < lines.len() {
        string line = lines.get(i);
        if line.contains("#T") {
            found = found + 1;
        }
        i += 1;
    }

    if found == 0 {
        print(bold_yellow("warning") + ": no test annotations found in " + bold_slate(path));
        print("add " + bold("#T expected output: ...") + " comments to your file");
        return;
    }

    print(bold_slate("slate") + " found " + string(found) + " test annotation(s) in " + bold_slate(path));
    print(bold_yellow("note") + ": test execution is not yet available — coming in 0.3.0");
}
