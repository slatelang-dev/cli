module run;

use slate;
use compiler;
use analyse;
use build;

void cmd_run(list(string) args) {
    mutable string path = "";
    mutable string verbosity = "normal";
    mutable int arg_i = 1;

    while arg_i < args.len() {
        string a = args.get(arg_i);
        if a == "--verbose" { verbosity = "verbose"; arg_i = arg_i + 1; }
        else if a == "--quiet" { verbosity = "quiet"; arg_i = arg_i + 1; }
        else { break; }
    }

    mutable int pass_from = arg_i;

    mutable bool is_bare = false;
    mutable bool has_project = false;
    mutable Project p = make_project("", "", "", "", "", false, "", "", "", "");
    if file("slate.toml").exists() {
        p = load_project(file("slate.toml").read());
        is_bare = p.bare;
        has_project = true;
        if project_valid(p) == false {
            err("invalid slate.toml — missing name or entry");
            return;
        }
        path = p.entry;
    } else {
        pass_from = arg_i + 1;
        if arg_i < args.len() { path = args.get(arg_i); }
    }

    if path == "" {
        print("slate run: no file given.");
        if has_project {
            print("usage: " + bold_slate("slate run"));
        } else {
            print("usage: " + bold_slate("slate run <file.slt>"));
        }
        return;
    }

    if file(path).exists() == false {
        err("file not found: " + bold_slate(path));
        return;
    }

    mutable AnalysisResult ar = analyse_source(path, is_bare, false);

    if ar.errors.len() > 0 {
        string source = file(path).read();
        string output = render_all(ar.errors, ar.warnings, source);
        print(output);
        return;
    }

    if has_project == false {
        string source = file(path).read();
        ParseResult p_res = parse(source);
        if p_res.success == false {
            err(p_res.message);
            return;
        }
        mutable Registry reg = seed_c_runtime(new_registry());
        reg = register_program(reg, p_res.node);
        string c_code = emit_source(p_res.node, reg);
        if c_code.len() == 0 {
            err("no code emitted");
            return;
        }
        if verbosity == "verbose" { print(gray("  emitting source ✓")); }
        string out_dir = "builds/";
        string cache_dir = "builds/.cache/";
        run("mkdir", "-p", out_dir);
        run("mkdir", "-p", cache_dir);
        string mod_hash = path.hash();
        string c_path = cache_dir + mod_hash + ".c";
        string obj_path = cache_dir + mod_hash + ".o";
        file(c_path).write(c_code);
        string runtime_dir = home() + "/.slate/deps/runtime/";
        string bin_path = out_dir + "run_" + mod_hash;
        mutable list(string) comp_args = empty;
        comp_args = comp_args.add("clang");
        comp_args = comp_args.add("-c");
        comp_args = comp_args.add(c_path);
        comp_args = comp_args.add("-o");
        comp_args = comp_args.add(obj_path);
        comp_args = comp_args.add("-O2");
        comp_args = comp_args.add("-fno-strict-aliasing");
        comp_args = comp_args.add("-I");
        comp_args = comp_args.add(runtime_dir);
        run(comp_args);
        if file(obj_path).exists() == false {
            err("compilation failed");
            return;
        }
        mutable list(string) link_args = empty;
        link_args = link_args.add("clang");
        link_args = link_args.add(obj_path);
        link_args = link_args.add("-o");
        link_args = link_args.add(bin_path);
        run(link_args);
        if file(bin_path).exists() == false {
            err("linking failed");
            return;
        }
        mutable list(string) exec_args = empty;
        exec_args = exec_args.add(bin_path);
        mutable int ai = pass_from;
        while ai < args.len() {
            exec_args = exec_args.add(args.get(ai));
            ai += 1;
        }
        exec(exec_args);
        return;
    }

    string bin_path = "builds/" + p.bin;
    run("rm", "-f", bin_path);

    if cmd_build(empty, verbosity) == false {
        return;
    }

    mutable list(string) run_args = empty;
    run_args = run_args.add(bin_path);
    mutable int ai = pass_from;
    while ai < args.len() {
        run_args = run_args.add(args.get(ai));
        ai += 1;
    }
    exec(run_args);
}
