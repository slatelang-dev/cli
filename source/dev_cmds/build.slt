module build;

use slate;
use compiler;
use build_manifest;
use build_pipeline;

bool cmd_build(list(string) args, string verbosity) {
    Project p = load_project(file("slate.toml").read());

    if project_valid(p) == false {
        err("invalid or missing slate.toml");
        hint("make sure your slate.toml has a name and entry field");
        return false;
    }

    if p.toolchain_version != "" and p.toolchain_version != compiler_version() {
        warn("project expects compiler v" + p.toolchain_version);
    }

    mutable string opt = p.opt;
    mutable string target = p.target;
    mutable string vb = verbosity;
    mutable int ai = 1;
    while ai < args.len() {
        string a = args.get(ai);
        if a == "--debug" { opt = "debug"; }
        else if a == "--release" { opt = "release"; }
        else if a == "--release-fast" { opt = "release-fast"; }
        else if a == "--verbose" { vb = "verbose"; }
        else if a == "--quiet" { vb = "quiet"; }
        else if a == "--target" {
            ai = ai + 1;
            if ai < args.len() { target = args.get(ai); }
        }
        ai = ai + 1;
    }
    if opt == "" { opt = "release"; }
    list(string) cflags = resolve_cflags(opt, target);

    if vb != "quiet" { print(bold("Building ") + bold_slate(p.name) + "..."); }

    LoadedModule entry = load_entry(p);

    if entry.success == false {
        err(entry.error);
        return false;
    }

    string out_dir = "builds/";
    string cache_dir = "builds/.cache/";
    string bin_path = out_dir + p.bin;

    run("mkdir", "-p", out_dir);
    run("mkdir", "-p", cache_dir);

    mutable table(string, string) manifest = load_manifest(cache_dir);

    string source_dir = "source";
    mutable list(ModuleStub) stubs = discover_modules(entry.ast, source_dir, empty);
    mutable bool entry_already_found = false;
    mutable int si = 0;
    while si < stubs.len() {
        if stubs.get(si).path == p.entry {
            entry_already_found = true;
        }
        si = si + 1;
    }
    if entry_already_found == false {
        stubs = stubs.add(ModuleStub(name: p.name, path: p.entry));
    }
    if vb != "quiet" { print(gray("  modules discovered ✓")); }

    mutable list(LoadedModule) modules = load_modules(stubs);

    mutable table(string, Node) parsed_asts = empty;
    mutable Registry reg = seed_c_runtime(new_registry());
    mutable int pi = 0;
    while pi < modules.len() {
        LoadedModule m = modules.get(pi);
        if m.success {
            ParseResult p_res = parse(m.source);
            if p_res.success {
                reg = register_program(reg, p_res.node);
                parsed_asts = parsed_asts.set(m.path, p_res.node);
            } else {
                err(m.name + ": " + p_res.message);
            }
        }
        pi = pi + 1;
    }

    mutable list(string) obj_paths = empty;
    mutable list(string) to_c_paths = empty;
    mutable list(string) to_mod_names = empty;
    mutable list(string) to_mod_paths = empty;
    mutable list(string) to_hashes = empty;
    mutable int emit_count = 0;

    list(LoadedModule) ordered = reverse_modules(modules);

    build_emit_headers(ordered, parsed_asts, reg, cache_dir);

    mutable int i = 0;
    while i < ordered.len() {
        LoadedModule m = ordered.get(i);
        string mod_name = m.name;
        string mod_path = m.path;
        string source_content = m.source;
        string source_hash = source_content.hash();

        string obj_path = cache_dir + mod_path.hash() + ".o";
        string c_path = cache_dir + mod_path.hash() + ".c";

        mutable bool needs_compile = true;
        if file(obj_path).exists() {
            if manifest.has(mod_path) {
                if manifest.get(mod_path) == source_hash {
                    obj_paths = obj_paths.add(obj_path);
                    needs_compile = false;
                }
            }
        }

        if needs_compile {
            mutable string c_code = "";
            if parsed_asts.has(m.path) {
                Node parsed = parsed_asts.get(m.path);
                c_code = emit_source(parsed, reg);
            }
            if c_code.len() > 0 {
                if vb == "verbose" { print(gray("  emitting " + mod_name + " ✓")); }
                file(c_path).write(c_code);
                to_c_paths = to_c_paths.add(c_path);
                to_mod_names = to_mod_names.add(mod_name);
                to_mod_paths = to_mod_paths.add(mod_path);
                to_hashes = to_hashes.add(source_hash);
                emit_count = emit_count + 1;
                if vb == "normal" {
                    write("\r  emitting... " + string(emit_count) + "/" + string(ordered.len()));
                }
            }
        }

        i = i + 1;
    }

    if vb == "normal" and emit_count > 0 {
        write("\r  emitted " + string(emit_count) + "/" + string(ordered.len()) + "\n");
    }

    mutable int mi = 0;
    while mi < to_c_paths.len() {
        manifest = manifest.set(to_mod_paths.get(mi), to_hashes.get(mi));
        mi = mi + 1;
    }
    save_manifest(cache_dir, manifest);

    string runtime_dir = home() + "/.slate/deps/runtime/";
    list(string) compiled_objs = build_compile(to_c_paths, to_mod_names, to_mod_paths, cache_dir, runtime_dir, vb, cflags);

    mutable int oi = 0;
    while oi < compiled_objs.len() {
        obj_paths = obj_paths.add(compiled_objs.get(oi));
        oi = oi + 1;
    }

    mutable list(string) link_flags = empty;
    mutable int lfi = 0;
    while lfi < cflags.len() {
        if cflags.get(lfi) == "-g" {
            link_flags = link_flags.add("-g");
        }
        lfi = lfi + 1;
    }
    if build_link(obj_paths, bin_path, link_flags) {
        if vb != "quiet" { done("built " + bin_path); }
        return true;
    }
    return false;
}
