module build;

use slate;
use compiler;
use build_manifest;

void build_emit_headers(list(LoadedModule) ordered, table(string, Node) parsed_asts, Registry reg, string cache_dir) {
    mutable string header_content = "#ifndef SLATE_FWD_H\n#define SLATE_FWD_H\n\n#include \"slate_runtime.h\"\n\n";
    mutable bool has_any_headers = false;

    list(string) struct_names = reg.struct_names.keys();
    mutable int sni = 0;
    while sni < struct_names.len() {
        string sname = struct_names.get(sni);
        header_content = header_content + "typedef struct slate_" + sname + " slate_" + sname + ";\n";
        sni = sni + 1;
    }
    header_content = header_content + "\n";

    mutable string all_structs = "";
    mutable string all_enums = "";
    mutable string all_fns = "";
    mutable string seen_fn_names = "";
    mutable int hi = 0;
    while hi < ordered.len() {
        LoadedModule m = ordered.get(hi);
        if parsed_asts.has(m.path) {
            Node parsed = parsed_asts.get(m.path);
            string e = emit_enums_only(parsed, reg);
            if e.len() > 0 {
                all_enums = all_enums + e + "\n";
                has_any_headers = true;
            }
            string s = emit_structs_only(parsed, reg);
            if s.len() > 0 {
                all_structs = all_structs + s + "\n";
                has_any_headers = true;
            }
            mutable int ci = 0;
            while ci < parsed.children.len() {
                Node decl = parsed.children.get(ci);
                if decl.kind == NodeKind.FnDecl {
                    string fn_name = decl.value;
                    if seen_fn_names.contains("|" + fn_name + "|") == false {
                        all_fns = all_fns + emit_fn_prototype(decl, reg);
                        seen_fn_names = seen_fn_names + "|" + fn_name + "|";
                        has_any_headers = true;
                    }
                }
                ci = ci + 1;
            }
        }
        hi = hi + 1;
    }
    header_content = header_content + all_enums + all_structs + all_fns;
    header_content = header_content + "#endif // SLATE_FWD_H\n";
    if has_any_headers {
        file(cache_dir + "slate_fwd.h").write(header_content);
    }
}

list(string) build_compile(list(string) to_c_paths, list(string) to_mod_names, list(string) to_mod_paths, string cache_dir, string runtime_dir, bool silent) {
    mutable list(string) obj_paths = empty;
    mutable int ci = 0;
    while ci < to_c_paths.len() {
        string c_path = to_c_paths.get(ci);
        string mod_name = to_mod_names.get(ci);
        string mod_path = to_mod_paths.get(ci);
        string obj_path = cache_dir + mod_path.hash() + ".o";

        run("clang", "-c", c_path, "-o", obj_path, "-O2", "-fno-strict-aliasing", "-I", runtime_dir);
        if file(obj_path).exists() == false {
            print(red("  failed: " + mod_name + " ✗"));
            print(gray("  clang -c " + c_path + " -o " + obj_path + " -O2 -fno-strict-aliasing -I " + runtime_dir));
            return obj_paths;
        } else {
            obj_paths = obj_paths.add(obj_path);
            if silent == false { print(gray("  compiling " + mod_name + " ✓")); }
        }
        ci = ci + 1;
    }
    return obj_paths;
}

bool build_link(list(string) obj_paths, string bin_path) {
    mutable list(string) link_args = empty;
    link_args = link_args.add("clang");
    mutable int li = 0;
    while li < obj_paths.len() {
        link_args = link_args.add(obj_paths.get(li));
        li = li + 1;
    }
    link_args = link_args.add("-o");
    link_args = link_args.add(bin_path);
    run(link_args);

    if file(bin_path).exists() {
        return true;
    } else {
        mutable string link_cmd = "";
        mutable int lk = 0;
        while lk < link_args.len() {
            if lk > 0 { link_cmd = link_cmd + " "; }
            link_cmd = link_cmd + link_args.get(lk);
            lk = lk + 1;
        }
        print(red("  failed... link ✗"));
        print(gray("  " + link_cmd));
        return false;
    }
}

void cmd_build(list(string) args, bool silent) {
    Project p = load_project(file("slate.toml").read());

    if project_valid(p) == false {
        print(red("error") + ": invalid or missing slate.toml");
        print("make sure your slate.toml has a name and entry field");
        return;
    }

    if silent == false { print(bold("Building ") + bold_slate(p.name) + "..."); }

    LoadedModule entry = load_entry(p);

    if entry.success == false {
        print(red("error") + ": " + entry.error);
        return;
    }

    string out_dir = "builds/";
    string cache_dir = "builds/.cache/";
    string bin_path = out_dir + p.bin;

    run("mkdir", "-p", out_dir);
    run("mkdir", "-p", cache_dir);

    mutable table(string, string) manifest = load_manifest(cache_dir);

    string source_dir = "source";
    mutable list(ModuleStub) stubs = discover_modules(entry.ast, source_dir, empty);
    mutable bool entry_already_found = false;
    mutable int si = 0;
    while si < stubs.len() {
        if stubs.get(si).path == p.entry {
            entry_already_found = true;
        }
        si = si + 1;
    }
    if entry_already_found == false {
        stubs = stubs.add(ModuleStub(name: p.name, path: p.entry));
    }
    if silent == false { print(gray("  modules discovered ✓")); }

    mutable list(LoadedModule) modules = load_modules(stubs);

    mutable table(string, Node) parsed_asts = empty;
    mutable Registry reg = seed_c_runtime(new_registry());
    mutable int pi = 0;
    while pi < modules.len() {
        LoadedModule m = modules.get(pi);
        if m.success {
            ParseResult p_res = parse(m.source);
            if p_res.success {
                reg = register_program(reg, p_res.node);
                parsed_asts = parsed_asts.set(m.path, p_res.node);
            } else {
                print(red("error") + ": " + m.name + ": " + p_res.message);
            }
        }
        pi = pi + 1;
    }

    mutable list(string) obj_paths = empty;
    mutable list(string) to_c_paths = empty;
    mutable list(string) to_mod_names = empty;
    mutable list(string) to_mod_paths = empty;
    mutable list(string) to_hashes = empty;

    list(LoadedModule) ordered = reverse_modules(modules);

    build_emit_headers(ordered, parsed_asts, reg, cache_dir);

    mutable int i = 0;
    while i < ordered.len() {
        LoadedModule m = ordered.get(i);
        string mod_name = m.name;
        string mod_path = m.path;
        string source_content = m.source;
        string source_hash = source_content.hash();

        string obj_path = cache_dir + mod_path.hash() + ".o";
        string c_path = cache_dir + mod_path.hash() + ".c";

        mutable bool needs_compile = true;
        if file(obj_path).exists() {
            if manifest.has(mod_path) {
                if manifest.get(mod_path) == source_hash {
                    obj_paths = obj_paths.add(obj_path);
                    needs_compile = false;
                }
            }
        }

        if needs_compile {
            mutable string c_code = "";
            if parsed_asts.has(m.path) {
                Node parsed = parsed_asts.get(m.path);
                c_code = emit_source(parsed, reg);
            }
            if c_code.len() > 0 {
                if silent == false { print(gray("  emitting " + mod_name + " ✓")); }
                file(c_path).write(c_code);
                to_c_paths = to_c_paths.add(c_path);
                to_mod_names = to_mod_names.add(mod_name);
                to_mod_paths = to_mod_paths.add(mod_path);
                to_hashes = to_hashes.add(source_hash);
            }
        }

        i = i + 1;
    }

    mutable int mi = 0;
    while mi < to_c_paths.len() {
        manifest = manifest.set(to_mod_paths.get(mi), to_hashes.get(mi));
        mi = mi + 1;
    }
    save_manifest(cache_dir, manifest);

    string runtime_dir = home() + "/.slate/deps/runtime/";
    list(string) compiled_objs = build_compile(to_c_paths, to_mod_names, to_mod_paths, cache_dir, runtime_dir, silent);

    mutable int oi = 0;
    while oi < compiled_objs.len() {
        obj_paths = obj_paths.add(compiled_objs.get(oi));
        oi = oi + 1;
    }

    if build_link(obj_paths, bin_path) {
        if silent == false { print(bold_green("built") + " " + bin_path + " ✓"); }
    }
}
