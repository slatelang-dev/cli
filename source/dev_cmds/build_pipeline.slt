module build_pipeline;

use slate;
use compiler;

list(string) resolve_cflags(string opt, string target) {
    mutable list(string) flags = empty;
    if opt == "debug" {
        flags = flags.add("-O0");
        flags = flags.add("-g");
    } else if opt == "release-fast" {
        flags = flags.add("-O3");
    } else {
        flags = flags.add("-O2");
    }
    if target != "" {
        if target == "x86-64-v3" { flags = flags.add("-march=x86-64-v3"); }
        else if target == "x86-64-v4" { flags = flags.add("-march=x86-64-v4"); }
        else if target == "znver3" { flags = flags.add("-march=znver3"); }
        else if target == "znver4" { flags = flags.add("-march=znver4"); }
        else if target == "znver5" { flags = flags.add("-march=znver5"); }
        else if target == "native" { flags = flags.add("-march=native"); }
        else if target == "aarch64" {
            flags = flags.add("--target");
            flags = flags.add("aarch64-linux-gnu");
        }
        else if target == "riscv64" {
            flags = flags.add("--target");
            flags = flags.add("riscv64-linux-gnu");
        }
    } else if opt == "release-fast" {
        flags = flags.add("-march=native");
    }
    return flags;
}

void build_emit_headers(list(LoadedModule) ordered, table(string, Node) parsed_asts, Registry reg, string cache_dir) {
    mutable string header_content = "#ifndef SLATE_FWD_H\n#define SLATE_FWD_H\n\n#include \"slate_runtime.h\"\n\n";
    mutable bool has_any_headers = false;

    list(string) struct_names = reg.struct_names.keys();
    mutable int sni = 0;
    while sni < struct_names.len() {
        string sname = struct_names.get(sni);
        header_content = header_content + "typedef struct slate_" + sname + " slate_" + sname + ";\n";
        sni = sni + 1;
    }
    header_content = header_content + "\n";

    mutable string all_structs = "";
    mutable string all_enums = "";
    mutable string all_fns = "";
    mutable string seen_fn_names = "";
    mutable int hi = 0;
    while hi < ordered.len() {
        LoadedModule m = ordered.get(hi);
        if parsed_asts.has(m.path) {
            Node parsed = parsed_asts.get(m.path);
            string e = emit_enums_only(parsed, reg);
            if e.len() > 0 {
                all_enums = all_enums + e + "\n";
                has_any_headers = true;
            }
            string s = emit_structs_only(parsed, reg);
            if s.len() > 0 {
                all_structs = all_structs + s + "\n";
                has_any_headers = true;
            }
            mutable int ci = 0;
            while ci < parsed.children.len() {
                Node decl = parsed.children.get(ci);
                if decl.kind == NodeKind.FnDecl {
                    string fn_name = decl.value;
                    if seen_fn_names.contains("|" + fn_name + "|") == false {
                        all_fns = all_fns + emit_fn_prototype(decl, reg);
                        seen_fn_names = seen_fn_names + "|" + fn_name + "|";
                        has_any_headers = true;
                    }
                }
                ci = ci + 1;
            }
        }
        hi = hi + 1;
    }
    header_content = header_content + all_enums + all_structs + all_fns;
    header_content = header_content + "#endif // SLATE_FWD_H\n";
    if has_any_headers {
        file(cache_dir + "slate_fwd.h").write(header_content);
    }
}

list(string) build_compile(list(string) to_c_paths, list(string) to_mod_names, list(string) to_mod_paths, string cache_dir, string runtime_dir, bool silent, list(string) cflags) {
    mutable list(string) obj_paths = empty;
    mutable int ci = 0;
    while ci < to_c_paths.len() {
        string c_path = to_c_paths.get(ci);
        string mod_name = to_mod_names.get(ci);
        string mod_path = to_mod_paths.get(ci);
        string obj_path = cache_dir + mod_path.hash() + ".o";

        mutable list(string) compile_args = empty;
        compile_args = compile_args.add("clang");
        compile_args = compile_args.add("-c");
        compile_args = compile_args.add(c_path);
        compile_args = compile_args.add("-o");
        compile_args = compile_args.add(obj_path);
        mutable int fi = 0;
        while fi < cflags.len() {
            compile_args = compile_args.add(cflags.get(fi));
            fi = fi + 1;
        }
        compile_args = compile_args.add("-fno-strict-aliasing");
        compile_args = compile_args.add("-I");
        compile_args = compile_args.add(runtime_dir);
        run(compile_args);
        if file(obj_path).exists() == false {
            err("failed: " + mod_name);
            return obj_paths;
        } else {
            obj_paths = obj_paths.add(obj_path);
            if silent == false { print(gray("  compiling " + mod_name + " ✓")); }
        }
        ci = ci + 1;
    }
    return obj_paths;
}

bool build_link(list(string) obj_paths, string bin_path, list(string) extra_flags) {
    mutable list(string) link_args = empty;
    link_args = link_args.add("clang");
    mutable int oi = 0;
    while oi < obj_paths.len() {
        link_args = link_args.add(obj_paths.get(oi));
        oi = oi + 1;
    }
    mutable int ei = 0;
    while ei < extra_flags.len() {
        link_args = link_args.add(extra_flags.get(ei));
        ei = ei + 1;
    }
    link_args = link_args.add("-o");
    link_args = link_args.add(bin_path);
    run(link_args);

    if file(bin_path).exists() {
        return true;
    } else {
        mutable string link_cmd = "";
        mutable int lk = 0;
        while lk < link_args.len() {
            if lk > 0 { link_cmd = link_cmd + " "; }
            link_cmd = link_cmd + link_args.get(lk);
            lk = lk + 1;
        }
        err("link failed");
        print(gray("  " + link_cmd));
        return false;
    }
}
